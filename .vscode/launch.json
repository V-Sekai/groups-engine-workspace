{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch launcher",
            "type": "cppdbg",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "miDebuggerPath": "/usr/bin/gdb",
            "args": [
                "--path",
                "groups",
                "-e"
            ],
            "program": "${workspaceFolder}/godot-launcher/bin/godot.linuxbsd.opt.tools.64.llvm",
            "visualizerFile": "${workspaceFolder}/godot-launcher/platform/windows/godot.natvis",
            "preLaunchTask": "Build Linux Web Launcher",
        },
    ],
}
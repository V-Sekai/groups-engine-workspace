{
  // See https://go.microsoft.com/fwlink/?LinkId=733558
  // for the documentation about the tasks.json format
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Linux web launcher",
      "type": "shell",
      "command": "scons -j`nproc` platform=linuxbsd disable_2d=yes deprecated=no target=release_debug custom_modules=../groups_godot_modules_javascript",
      "options": {
        "cwd": "${workspaceFolder}/godot-launcher"
      },
      "problemMatcher": ["$gcc"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "dependsOn": [
        "Update repos.sh",
        "Build Web"
      ]
    },
    {
      "label": "Build Web",
      "type": "shell",
      "command": "scons -j`nproc` platform=javascript disable_2d=yes deprecated=no target=release initial_memory=256 custom_modules=../groups_godot_modules_javascript",
      "options": {
        "cwd": "${workspaceFolder}/godot-launcher"
      },
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "Update repos.sh",
      "type": "shell",
      "command": "./update_repos.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}

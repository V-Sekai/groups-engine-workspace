{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build",
            "type": "shell",
            "command": "scons platform=linuxbsd -j`nproc` bits=64 use_lld=yes use_llvm=yes use_thinlto=yes target=release_debug",
            "problemMatcher": [],
            "options": {
                "cwd": "${workspaceFolder}/godot"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}